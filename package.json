{
  "name": "powerflex-csi-intelligence",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run db:generate && npm run build -w packages/shared-schema && npm run build -w packages/db && npm run build -w packages/ingestion && npm run build -w apps/api && npm run build -w apps/worker && npm run build -w apps/web",
    "dev": "sh -c 'set -a; . ./.env; set +a; exec concurrently -n api,worker,web -c cyan,magenta,green \"npm run dev -w apps/api\" \"npm run dev -w apps/worker\" \"npm run dev -w apps/web\"'",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema packages/db/prisma/schema.prisma",
    "db:dev": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "sync:once": "sh -c 'set -a; . ./.env; set +a; npm run sync:once -w apps/worker'"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.34.1",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "ioredis": "^5.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "semver": "^7.6.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/semver": "^7.5.8",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
